# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Meta WhatsApp Cloud API
META_WHATSAPP_TOKEN=xxx           # System User permanent token
META_PHONE_NUMBER_ID=xxx          # Registered phone number ID
META_WABA_ID=xxx                  # WhatsApp Business Account ID
META_APP_SECRET=xxx               # For webhook signature verification
META_VERIFY_TOKEN=xxx             # Custom string for webhook setup (you choose this)

# App
NEXT_PUBLIC_APP_URL=https://app.mariomoreno.work
